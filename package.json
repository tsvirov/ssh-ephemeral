{
  "name": "ssh-ephemeral",
  "version": "0.1.0",
  "description": "SSH into a fresh sandbox — a container spins up on connect and tears down on disconnect, per-user configurable via a simple template config. No manual provisioning, no leftover state.",
  "type": "module",
  "license": "MIT",
  "author": "Ilya Tsvirov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsvirov/ssh-ephemeral.git"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ssh-ephemeral": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "js-yaml": "^4.1.0",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.29",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/ssh2": "^1.15.1",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
